# Resend API key — get from https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# Email address that receives all quote submissions
RECIPIENT_EMAIL=joshrunas12@gmail.com

# From address — must be a verified Resend domain.
# For testing you can omit this and the default onboarding@resend.dev is used
# (only works when RECIPIENT_EMAIL matches the Resend account email).
# For production set this to something like: noreply@yourdomain.com
# FROM_EMAIL=noreply@yourdomain.com
